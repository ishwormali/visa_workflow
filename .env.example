VITE_GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/drive https://www.googleapis.com/auth/gmail.compose
VITE_GOOGLE_DRIVE_ROOT_FOLDER_ID=replace-with-documents-requested-folder-id
VITE_GOOGLE_DRIVE_DOCUMENT_LIST_FILE_ID=replace-with-document-list-file-id

# Server-only credentials for OAuth code exchange.
GOOGLE_CLIENT_SECRET=replace-with-client-secret
